<%- include("../partials/header") %>
<%
  function toLocalInput(d) {
    const date = new Date(d);
    const offset = date.getTimezoneOffset() * 60000;
    return new Date(date.getTime() - offset).toISOString().slice(0, 16);
  }
  const tomorrow = new Date(Date.now() + 86400000);
  const minDateStr = toLocalInput(tomorrow).slice(0, 10) + 'T00:00';
%>


<div class="event-form-page">
  <div class="event-form-card">
    <h1>Edit Event</h1>

    <% if (errors.length > 0) { %>
      <div class="form-error-list">
        <ul>
          <% errors.forEach(err => { %><li><%= err %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/events/<%= event._id %>/update" method="POST">

      <div class="form-group">
        <label for="title">Event Title</label>
        <input type="text" id="title" name="title" value="<%= event.title %>" required>
      </div>

      <div class="form-group">
        <label for="venue">Venue</label>
        <input type="text" id="venue" name="venue" value="<%= event.venue %>" required>
      </div>

      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category" required>
          <option value="">-- Select a Category --</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= event.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" required><%= event.description %></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="startDate">Start Date &amp; Time</label>
          <input type="datetime-local" id="startDate" name="startDate" min="<%= minDateStr %>" value="<%= toLocalInput(event.startDate) %>" required>
        </div>
        <div class="form-group">
          <label for="endDate">End Date &amp; Time</label>
          <input type="datetime-local" id="endDate" name="endDate" min="<%= minDateStr %>" value="<%= toLocalInput(event.endDate) %>" required>
        </div>
      </div>

      <div class="form-group">
        <label for="maxParticipants">Max Participants</label>
        <input type="number" id="maxParticipants" name="maxParticipants" value="<%= event.maxParticipants %>" min="1" required>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Save Changes</button>
        <a href="/events/<%= event._id %>" style="display:flex;align-items:center;justify-content:center;border:1px solid #dbdae3;border-radius:4px;font-size:0.9rem;font-weight:600;color:#1e0a3c;text-decoration:none;padding:0.5rem 1.125rem;">Cancel</a>
      </div>

    </form>

    <hr>
    <form action="/events/<%= event._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this event?')">
      <button type="submit" class="btn-danger">Delete Event</button>
    </form>

  </div>
</div>

<%- include("../partials/footer") %>
