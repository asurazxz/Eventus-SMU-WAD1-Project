<%- include("../partials/header") %>

<%
const catColor = {
  'Music': '#7c3aed',
  'Sports': '#059669',
  'Technology': '#0ea5e9',
  'Food & Drink': '#f59e0b',
  'Arts & Culture': '#ec4899',
  'Networking': '#6366f1',
  'Education': '#2563eb',
  'Health & Wellness': '#10b981',
  'Comedy': '#f97316',
  'Fashion': '#db2777',
  'Gaming': '#8b5cf6',
  'Film & Media': '#1d4ed8',
  'Business': '#0891b2',
  'Community': '#65a30d',
  'Travel & Outdoors': '#0284c7',
  'Charity & Causes': '#dc2626',
  'Family & Kids': '#d97706',
  'Religion & Spirituality': '#9333ea',
  'Politics': '#b45309',
  'Science': '#0369a1'
};
%>

<!-- Hero  -->
<div class="events-hero">
  <h1 class="events-hero-title">Discover Events</h1>
  <p class="events-hero-sub">Find and join the events that excite you</p>

  <form method="GET" action="/events" class="hero-search-form">
    <div class="hero-search-bar">
      <input
        type="search"
        name="q"
        placeholder="Search by title..."
        value="<%= q %>"
        class="hero-input"
      />
      <select name="category" class="hero-select">
        <option value="">All Categories</option>
        <% CATEGORIES.forEach(cat => { %>
          <option value="<%= cat %>" <%= category === cat ? "selected" : "" %>><%= cat %></option>
        <% }) %>
      </select>
      <select name="sort" class="hero-select">
        <option value="date_asc" <%= sort === "date_asc"  ? "selected" : "" %>>Date (earliest)</option>
        <option value="title_asc" <%= sort === "title_asc" ? "selected" : "" %>>Title (A–Z)</option>
        <option value="category" <%= sort === "category"  ? "selected" : "" %>>Category</option>
      </select>
      <button type="submit" class="hero-btn">Search</button>
    </div>
    <% if (q || category) { %>
      <a href="/events" class="hero-clear">Clear filters</a>
    <% } %>
  </form>
</div>

<!-- Trending + Results -->
<div class="events-page">

  <% if (!q && !category && trendingEvents && trendingEvents.length > 0) { %>
  <div class="trending-section">
    <h2 class="trending-heading">Trending Now</h2>
    <div class="trending-grid">
      <% trendingEvents.forEach((item, i) => { %>
        <% const tColor = catColor[item.event.category] || '#5b21b6'; %>
        <a href="/events/<%= item.event._id %>" class="trending-card">
          <div class="trending-color-bar" style="background:<%= tColor %>"></div>
          <div class="trending-card-body">
            <div class="trending-rank">#<%= i + 1 %></div>
            <div class="trending-cat" style="color:<%= tColor %>"><%= item.event.category %></div>
            <div class="eb-card-title"><%= item.event.title %></div>
            <% if (item.event.startDate) { %>
              <div class="eb-card-meta"><%= new Date(item.event.startDate).toLocaleString("en-SG", { day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" }) %></div>
            <% } %>
          </div>
          <div class="trending-card-footer">
            <span class="trending-rsvp-badge" style="background:<%= tColor %>20;color:<%= tColor %>"><%= item.count %> RSVP<%= item.count === 1 ? '' : 's' %></span>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <div class="events-results-row">
    <% if (q || category) { %>
      <h2 class="events-results-heading">
        <strong><%= upcoming.length %></strong> result<%= upcoming.length !== 1 ? 's' : '' %>
        <% if (q) { %> for "<em><%= q %></em>"<% } %>
        <% if (category) { %> in <em><%= category %></em><% } %>
      </h2>
    <% } else { %>
      <h2 class="events-results-heading">Upcoming Event<%= upcoming.length !== 1 ? 's' : '' %>: <%= upcoming.length %></h2>
    <% } %>
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <a href="/events/new" class="btn-primary" style="padding:0.5rem 1.125rem;border-radius:4px;font-size:0.9rem;font-weight:600;text-decoration:none;">+ Create Event</a>
    <% } %>
  </div>

  <% if (upcoming.length === 0) { %>
  <div class="events-empty">
    <p>No upcoming events found. <a href="/events">View all events</a></p>
  </div>
  <% } else { %>

  <div class="eb-grid">
    <% upcoming.forEach(event => { %>
      <% const color = catColor[event.category] || '#5b21b6'; %>
      <a href="/events/<%= event._id %>" class="eb-card">
        <div class="eb-card-color-bar" style="background:<%= color %>"></div>
        <div class="eb-card-body">
          <div class="eb-card-category" style="color:<%= color %>"><%= event.category %></div>
          <div class="eb-card-title"><%= event.title %></div>
          <div class="eb-card-meta"><%= new Date(event.startDate).toLocaleString("en-SG", { weekday:"short", day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" }) %></div>
          <div class="eb-card-meta"><%= event.venue %></div>
          <% if (event.owner && event.owner.name) { %>
            <div class="eb-card-meta eb-card-owner">By <%= event.owner.name %></div>
          <% } %>
        </div>
        <div class="eb-card-footer">
          <span class="eb-card-spots"><%= event.maxParticipants %> spots</span>
          <span class="eb-card-view" style="color:<%= color %>">View &rarr;</span>
        </div>
      </a>
    <% }) %>
  </div>

<% } %>
</div>

<%- include("../partials/footer") %>
