<%- include("../partials/header") %>

<div class="auth-container">
  <h1>Sign Up</h1>
  <p>Create an account to start managing events.</p>

  <!-- Flash Messages -->
  <% if (success && success.length > 0) { %>
    <div class="flash flash-success">
      <%= success %>
    </div>
  <% } %>

  <% if (error && error.length > 0) { %>
    <div class="flash flash-error">
      <%= error %>
    </div>
  <% } %>

  <!-- Validation Errors -->
  <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
    <div class="flash flash-error">
      <ul>
        <% errors.forEach(function(error) { %>
          <li><%= error.msg %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <form action="/auth/signup" method="POST">
    <div class="form-group">
      <label for="name">Username</label>
      <input 
        type="text" 
        id="name" 
        name="name" 
        placeholder="Choose a username"
        value="<%= typeof oldInput !== 'undefined' && oldInput.name ? oldInput.name : '' %>"
        required
      >
      <small class="form-hint">Username must be unique (2-50 characters).</small>
    </div>

    <div class="form-group">
      <label for="email">Email</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        placeholder="Enter your email"
        value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email : '' %>"
        required
      >
    </div>

    <div class="form-group">
      <label for="phone">Phone Number</label>
      <div style="display:flex;align-items:center;gap:0.5rem;">
        <span style="font-size:0.95rem;color:#6f7287;white-space:nowrap;">+65</span>
        <input
          type="text"
          id="phone"
          name="phone"
          placeholder="8-digit local number"
          value="<%= typeof oldInput !== 'undefined' && oldInput.phone ? oldInput.phone : '' %>"
          maxlength="8"
          style="flex:1;"
          required
        >
      </div>
      <small class="form-hint">Singapore number, 8 digits (no country code).</small>
    </div>

    <div class="form-group">
      <label for="password">Password</label>
      <input
        type="password"
        id="password"
        name="password"
        placeholder="Minimum 8 characters, 1 number"
        required
      >
      <small class="form-hint">Password must be at least 8 characters and contain at least one number.</small>
    </div>

    <button type="submit" class="btn btn-primary">Sign Up</button>
  </form>

  <p class="auth-link">
    Already have an account? <a href="/auth/login">Login here</a>
  </p>
</div>

<%- include("../partials/footer") %>