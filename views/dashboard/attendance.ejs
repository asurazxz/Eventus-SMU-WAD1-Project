<%- include("../partials/header") %>
<%- include("../dashboardPartials/header") %>

<div class="participants-page">
  <%
    const checkedIn = (attendees || []).filter(a => a.checkedInAt);
    const notCheckedIn = (attendees || []).filter(a => !a.checkedInAt);
  %>
  <div class="participants-event-info">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
      <div>
        <h1><%= eventListing.title %></h1>
        <p>
          <%= new Date(eventListing.startDate).toLocaleString("en-SG", { day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" }) %>
          <% if (eventListing.endDate) { %>
            &ndash;
            <%= new Date(eventListing.endDate).toLocaleString("en-SG", { day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" }) %>
          <% } %>
        </p>
      </div>
      <div style="text-align:right;white-space:nowrap;">
        <span style="font-size:1.5rem;font-weight:700;color:var(--eb-orange);"><%= checkedIn.length %> / <%= attendees.length %></span>
        <div style="font-size:0.8rem;color:var(--eb-text-sec);margin-top:0.2rem;">Checked In / Total RSVPs</div>
      </div>
    </div>
  </div>

  <% if (!attendees || attendees.length === 0) { %>
    <p style="color:#6f7287;">No RSVPs for this event.</p>
  <% } else { %>

    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.25rem;">
      <div class="filter-tabs" style="margin-bottom:0;">
        <button class="ftab active" data-filter="all" onclick="filterAttendance('all', this)">All (<%= attendees.length %>)</button>
        <button class="ftab" data-filter="checked" onclick="filterAttendance('checked', this)">Checked In (<%= checkedIn.length %>)</button>
        <button class="ftab" data-filter="absent" onclick="filterAttendance('absent', this)">No Check-In (<%= notCheckedIn.length %>)</button>
      </div>
      <a href="/dashboard/events/<%= eventListing._id %>/attendance/export" style="font-size:0.875rem;font-weight:600;color:var(--eb-orange);text-decoration:none;">&#8595; Export CSV</a>
    </div>

    <table id="attendance-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Email</th>
          <th>RSVP Status</th>
          <th>Check-In Time</th>
          <th>RSVP Notes</th>
          <th>Owner Notes</th>
        </tr>
      </thead>
      <tbody>
        <% attendees.forEach((attendee, i) => { %>
          <tr data-checkin="<%= attendee.checkedInAt ? 'yes' : 'no' %>">
            <td><%= i + 1 %></td>
            <td><%= attendee.name %></td>
            <td><%= attendee.email %></td>
            <td>
              <% if (attendee.rsvpStatus === "confirmed") { %>
                <span class="badge badge-green">Confirmed</span>
              <% } else { %>
                <span class="badge badge-gray">Waitlist</span>
              <% } %>
            </td>
            <td style="font-size:0.85rem;color:#6f7287;">
              <% if (attendee.checkedInAt) { %>
                <span style="color:#16a34a;font-weight:600;">
                  <%= new Date(attendee.checkedInAt).toLocaleString("en-SG", { day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" }) %>
                </span>
              <% } else { %>
                &mdash;
              <% } %>
            </td>
            <td style="font-size:0.82rem;color:#6f7287;max-width:160px;">
              <%= attendee.rsvpNotes || '—' %>
            </td>
            <td style="min-width:180px;">
              <% if (attendee.checkedInAt && attendee.userId) { %>
                <form action="/dashboard/events/<%= eventListing._id %>/attendance/<%= attendee.userId %>/notes" method="POST">
                  <textarea
                    name="ownerNotes"
                    rows="2"
                    maxlength="500"
                    style="width:100%;font-size:0.82rem;border:1px solid #d1d5db;border-radius:4px;padding:4px;resize:vertical;box-sizing:border-box;"
                  ><%= attendee.ownerNotes || '' %></textarea>
                  <button type="submit" class="btn-primary btn-sm" style="margin-top:4px;font-size:0.75rem;">Save</button>
                </form>
              <% } else { %>
                <span style="color:#9ca3af;font-size:0.82rem;">—</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<script>
  function filterAttendance(filter, btn) {
    document.querySelectorAll('.ftab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    document.querySelectorAll('#attendance-table tbody tr').forEach(row => {
      const checkin = row.dataset.checkin;
      if (filter === 'all') {
        row.style.display = '';
      } else if (filter === 'checked') {
        row.style.display = checkin === 'yes' ? '' : 'none';
      } else {
        row.style.display = checkin === 'no' ? '' : 'none';
      }
    });
  }
</script>

<%- include("../partials/footer") %>
